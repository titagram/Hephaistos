  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "responses": {
      "Error": {
        "description": "Hades API error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing, expired, or invalid bearer token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "unauthorized": {
                "$ref": "#/components/examples/UnauthorizedError"
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Authenticated agent is not allowed to perform this action",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "forbidden": {
                "$ref": "#/components/examples/ForbiddenError"
              }
            }
          }
        }
      },
      "ValidationError": {
        "description": "Request validation failed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ValidationErrorResponse"
            },
            "examples": {
              "validation": {
                "$ref": "#/components/examples/ValidationError"
              }
            }
          }
        }
      }
    },
    "examples": {
      "UnauthorizedError": {
        "summary": "401 unauthorized",
        "value": {
          "error": {
            "code": "unauthorized",
            "message": "Authentication required."
          }
        }
      },
      "ForbiddenError": {
        "summary": "403 forbidden",
        "value": {
          "error": {
            "code": "forbidden",
            "message": "Agent is not allowed to access this workspace."
          }
        }
      },
      "ValidationError": {
        "summary": "422 validation error",
        "value": {
          "message": "The workspace binding id field is required.",
          "errors": {
            "workspace_binding_id": [
              "The workspace binding id field is required."
            ]
          }
        }
      },
      "MemoryProposalConflict": {
        "summary": "Memory proposal conflict",
        "value": {
          "status": "conflicted",
          "reason": "superseded_by_newer_memory",
          "proposal_id": "proposal_123"
        }
      },
      "MemoryProposalRefused": {
        "summary": "Memory proposal refused",
        "value": {
          "status": "refused",
          "reason": "project_policy_denied",
          "proposal_id": "proposal_123"
        }
      },
      "ExpiredJobStatus": {
        "summary": "Expired job transition",
        "value": {
          "job_id": "job_123",
          "status": "expired",
          "message": "Job deadline expired before local confirmation."
        }
      },
      "TruncatedArtifactUpload": {
        "summary": "Artifact upload with truncation metadata",
        "value": {
          "project_id": "project_123",
          "workspace_binding_id": "workspace_123",
          "schema": "hades.git_tree.v1",
          "artifact": {
            "truncated": true,
            "omitted": [
              {
                "path": "node_modules",
                "reason": "excluded_directory"
              }
            ]
          },
          "truncated": true,
          "redactions": 1
        }
      },
      "InboxPolling": {
        "summary": "Persistent Persephone inbox polling response",
        "value": {
          "events": [
            {
              "event_id": "evt_123",
              "event_type": "proposal.reviewed",
              "payload": {
                "message": "Proposal reviewed"
              }
            }
          ]
        }
      },
      "MemoryImportBundle": {
        "summary": "Shared-memory import bundle request",
        "value": {
          "project_id": "project_123",
          "workspace_binding_id": "workspace_123",
          "source": {
            "kind": "hades_local_memory",
            "schema": "hades.memory_import.v1"
          },
          "entries": [
            {
              "source_local_id": "local-memory-1",
              "source_hash": "sha256:example",
              "kind": "decision",
              "summary": "Use the backend as authoritative shared memory.",
              "payload": {
                "confidence": "high"
              },
              "provenance": {
                "source": "hades_local_cache"
              }
            }
          ]
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "ArtifactUploadRequest": {
        "type": "object",
        "required": [
          "project_id",
          "workspace_binding_id",
          "schema",
          "artifact"
        ],
        "properties": {
          "project_id": {
            "type": "string"
          },
          "agent_id": {
            "type": "string"
          },
          "workspace_binding_id": {
            "type": "string"
          },
          "job_id": {
            "type": "string"
          },
          "schema": {
            "type": "string",
            "enum": [
              "hades.git_tree.v1",
              "hades.symbols.v1",
              "hades.php_graph.v1",
              "hades.code_graph.v1"
            ]
          },
          "artifact": {
            "type": "object"
          },
          "sha256": {
            "type": "string"
          },
          "truncated": {
            "type": "boolean"
          },
          "redactions": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "DoctorReportRequest": {
        "type": "object",
        "required": [
          "project_id",
          "status",
          "payload"
        ],
        "properties": {
          "project_id": {
            "type": "string"
          },
          "workspace_binding_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "warning",
              "error",
              "failed"
            ]
          },
          "payload": {
            "type": "object"
          }
        }
      },
      "PersephoneMessageRequest": {
        "type": "object",
        "required": [
          "project_id",
          "event_type"
        ],
        "properties": {
          "project_id": {
            "type": "string"
          },
          "workspace_binding_id": {
            "type": "string"
          },
          "event_type": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        }
      },
      "ValidationErrorResponse": {
        "type": "object",
        "required": [
          "message",
          "errors"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "MemoryImportBundleRequest": {
        "type": "object",
        "required": [
          "project_id",
          "workspace_binding_id",
          "entries"
        ],
        "properties": {
          "project_id": {
            "type": "string"
          },
          "workspace_binding_id": {
            "type": "string"
          },
          "source": {
            "type": "object"
          },
          "entries": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
